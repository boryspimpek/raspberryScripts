# Wczytaj tylko wybrane kolumny i 100k wierszy (np. do testÃ³w)\
df = pd.read_csv(\
    "en.openfoodfacts.org.products.csv",\
    sep="\t",\
    usecols=["product_name", "energy-kcal_100g"],\
    nrows=100000\
)\
\
# WyczyÅƒ»Äƒ§ dane\
df = df.dropna(subset=["product_name", "energy-kcal_100g"])\
df = df.drop_duplicates(subset=["product_name"])\
\
# Prosty test wyszukiwania\
produkt = input("Podaj nazwÄƒ¹ produktu: ").lower()\
wyniki = df[df["product_name"].str.lower().str.contains(produkt)]\
\
if not wyniki.empty:\
    print(wyniki.head(5))\
else:\
\

